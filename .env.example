ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/REPLACE_WITH_KEY
POSITION_ID=5382694
# Or multiple positions (comma-separated):
# POSITION_IDS=5382694,1234567,7654321
CHECK_INTERVAL_SECONDS=60
ALERT_ON_START=false

# Daily asset digest (from DefiLlama yields)
ASSET_DIGEST_ENABLED=true
ASSET_DIGEST_TIMES=11:00,23:00
ASSET_DIGEST_TOP_N=10
LOCAL_TZ=Asia/Shanghai

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_username
SMTP_PASS=your_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

EMAIL_FROM=alerts@example.com
EMAIL_TO=you@example.com,other@example.com
